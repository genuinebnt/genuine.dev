# Copy to .env and fill in values.
# The justfile loads this automatically via `set dotenv-load`.

# Postgres connection — matches docker-compose.yml defaults
DATABASE_URL=postgres://folio:folio@localhost:5432/folio

# Auth — any strong secret (used to sign JWT tokens)
JWT_SECRET=change_me_to_a_long_random_string

# Admin credentials (single-user site)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# Upload directory (relative to backend working dir)
UPLOAD_DIR=./uploads

# Public site URL (used in feeds / emails)
SITE_URL=http://localhost:3000
