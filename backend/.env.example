# POSTGRES_PASSWORD=change-me-strong
# SITE_URL=https://genuine.dev
# DOMAIN=genuine.dev
# JWT_SECRET=change-me-long-random
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-strong   # REQUIRED in prod (no default)
